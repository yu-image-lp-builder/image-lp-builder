---
/**
 * PasswordGate
 *
 * Standalone HTML page (no PublicLayout to keep the surface small)
 * shown to visitors of a password-protected LP before they enter the
 * right password. Submits to the same URL via POST; the route
 * handler in [slug].astro / index.astro validates and either sets
 * the verify cookie + redirects or re-renders this page with an
 * error message.
 */

interface Props {
  /** What URL the form posts back to. */
  actionPath: string;
  /** When set, shown to the visitor (e.g. on a wrong-password retry). */
  errorMessage?: string;
  /** Title shown on the page (defaults to a generic line). */
  title?: string;
}

const {
  actionPath,
  errorMessage,
  title = 'パスワードを入力してください',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="robots" content="noindex" />
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f7fa;
      color: #1a1a1a;
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN',
        'Noto Sans JP', sans-serif;
    }
    .card {
      width: 100%;
      max-width: 420px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      padding: 2rem 1.75rem;
    }
    h1 {
      font-size: 1.1rem;
      margin: 0 0 0.5rem;
      font-weight: 600;
    }
    p.lead {
      margin: 0 0 1.25rem;
      font-size: 0.875rem;
      color: #4b5563;
      line-height: 1.6;
    }
    label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 500;
      margin-bottom: 0.375rem;
      color: #374151;
    }
    input[type='password'] {
      width: 100%;
      padding: 0.625rem 0.75rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    input[type='password']:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.18);
    }
    button {
      margin-top: 1rem;
      width: 100%;
      padding: 0.625rem 1rem;
      background: #1f2937;
      color: #fff;
      border: 0;
      border-radius: 6px;
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s;
    }
    button:hover { background: #111827; }
    .error {
      margin-top: 1rem;
      padding: 0.625rem 0.75rem;
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #b91c1c;
      border-radius: 6px;
      font-size: 0.8125rem;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>{title}</h1>
    <p class="lead">このページの閲覧にはパスワードが必要です。</p>
    <form method="post" action={actionPath}>
      <label for="password">パスワード</label>
      <input
        type="password"
        id="password"
        name="password"
        autocomplete="current-password"
        autofocus
        required
      />
      <button type="submit">表示する</button>
      {errorMessage && <div class="error" role="alert">{errorMessage}</div>}
    </form>
  </main>
</body>
</html>
