---
/**
 * CountdownBar
 *
 * Sticky bar rendered on top of (or beneath) a public LP that counts
 * down to a deadline. The tick logic is plain inline JS — no React on
 * the visitor side — so the public bundle stays small.
 *
 * On expiry the bar swaps to `expiredText` if provided, otherwise
 * removes itself from the DOM.
 */

import type { Countdown } from '../lib/content';

interface Props {
  countdown: Countdown;
}

const { countdown } = Astro.props;

const HEX_COLOR = /^#[0-9a-fA-F]{3,8}$/;
const safeColor = (v: string | undefined, fallback: string) =>
  v && HEX_COLOR.test(v) ? v : fallback;

const bg = safeColor(countdown.backgroundColor, '#dc2626');
const fg = safeColor(countdown.textColor, '#ffffff');
const positionClass =
  countdown.position === 'bottom' ? 'countdown-bottom' : 'countdown-top';

const initialMs = new Date(countdown.deadline).getTime() - Date.now();
const initialExpired = !Number.isFinite(initialMs) || initialMs <= 0;

// SSR-friendly initial markup. The client script overwrites the
// .countdown-time text every second.
---

{(!initialExpired || countdown.expiredText) && (
  <div
    class:list={['countdown-bar', positionClass]}
    style={`background:${bg};color:${fg}`}
    data-deadline={countdown.deadline}
    data-expired-text={countdown.expiredText ?? ''}
  >
    <div class="countdown-inner">
      {countdown.label && <span class="countdown-label">{countdown.label}</span>}
      <span class="countdown-time">
        {initialExpired ? countdown.expiredText : '...'}
      </span>
    </div>
  </div>
)}

<script>
  // Live-update every countdown bar on the page (there'll usually be 0 or 1).
  function tick() {
    const bars = document.querySelectorAll<HTMLElement>('.countdown-bar');
    if (bars.length === 0) return;

    const now = Date.now();
    bars.forEach((bar) => {
      const deadline = bar.dataset.deadline;
      if (!deadline) return;
      const expiredText = bar.dataset.expiredText ?? '';
      const time = bar.querySelector<HTMLElement>('.countdown-time');
      if (!time) return;

      const ms = new Date(deadline).getTime() - now;
      if (!Number.isFinite(ms) || ms <= 0) {
        if (expiredText) {
          time.textContent = expiredText;
          // Hide the label once expired so the message reads cleanly.
          const label = bar.querySelector<HTMLElement>('.countdown-label');
          if (label) label.style.display = 'none';
        } else {
          bar.remove();
        }
        return;
      }
      time.textContent = format(ms);
    });
  }

  function format(ms: number): string {
    const total = Math.floor(ms / 1000);
    const days = Math.floor(total / 86400);
    const hours = Math.floor((total % 86400) / 3600);
    const mins = Math.floor((total % 3600) / 60);
    const secs = total % 60;
    const pad = (n: number) => n.toString().padStart(2, '0');
    if (days > 0) return `${days}日 ${pad(hours)}:${pad(mins)}:${pad(secs)}`;
    return `${pad(hours)}:${pad(mins)}:${pad(secs)}`;
  }

  tick();
  setInterval(tick, 1000);
</script>

<style>
  .countdown-bar {
    position: fixed;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0.625rem 1rem;
    text-align: center;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
    /* Reserve enough breathing room above/below the LP body so the bar
       doesn't overlap content. The body padding is set on the public
       layout when a bar is present. */
  }

  .countdown-top {
    top: 0;
  }

  .countdown-bottom {
    bottom: 0;
    box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.15);
  }

  .countdown-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .countdown-label {
    opacity: 0.95;
  }

  .countdown-time {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
</style>
