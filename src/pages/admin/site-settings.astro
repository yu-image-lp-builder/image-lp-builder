---
/**
 * /admin/site-settings
 *
 * Site-wide settings — currently the tracking tag IDs (GTM, GA4,
 * Clarity, Meta Pixel) plus a custom HTML block injected into the
 * public LP <head>. Additional site-level settings are configured
 * on this page as they are added.
 */

import AdminLayout from '../../layouts/AdminLayout.astro';
import SiteSettingsPanel from '../../components/admin/SiteSettingsPanel';
import SiteMetaPanel from '../../components/admin/SiteMetaPanel';
import DomainSettingsPanel from '../../components/admin/DomainSettingsPanel';

export const prerender = false;
---

<AdminLayout title="サイト設定">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">サイト設定</h1>
    <p class="text-sm text-gray-600 mb-6">
      全 LP に共通で適用される設定。<br />LP 個別の設定は各 LP の編集画面から。
    </p>

    <div class="flex flex-col gap-6">
      <div><DomainSettingsPanel client:load /></div>
      <div><SiteMetaPanel client:load /></div>
      <div><SiteSettingsPanel client:load /></div>
    </div>
  </div>
</AdminLayout>
