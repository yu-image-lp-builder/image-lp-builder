---
/**
 * /admin/lps/new
 *
 * Form for creating a new LP. The self-hoster picks the slug here
 * (the URL path under which the LP will be served), and on submit
 * we POST to /api/lps and redirect to the new LP's edit screen.
 */

import AdminLayout from '../../../layouts/AdminLayout.astro';
import NewLpForm from '../../../components/admin/NewLpForm';

export const prerender = false;
---

<AdminLayout title="新規LP">
  <div class="max-w-xl mx-auto">
    <a
      href="/admin"
      class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block"
    >
      ← LP一覧に戻る
    </a>

    <h1 class="text-2xl font-bold text-gray-900 mb-2">新規LPを作成</h1>
    <p class="text-sm text-gray-600 mb-6">
      まず公開URL(slug)を決めます。<br />中身は作成後の編集画面で組み立てます。
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <NewLpForm client:load />
    </div>
  </div>
</AdminLayout>
